{
	"name": "@atharva-again/pi-tg",
	"version": "0.1.3",
	"description": "Telegram client for pi",
	"homepage": "https://github.com/atharva-again/pi#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/atharva-again/pi.git",
		"directory": "packages/telegram"
	},
	"bugs": {
		"url": "https://github.com/atharva-again/pi/issues"
	},
	"type": "module",
	"bin": {
		"pi-tg": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"pi",
		"telegram",
		"bot",
		"agent"
	],
	"author": "Pi contributors",
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "https://registry.npmjs.org/@earendil-works/pi-agent-core/-/pi-agent-core-0.80.8.tgz",
		"@earendil-works/pi-ai": "https://registry.npmjs.org/@earendil-works/pi-ai/-/pi-ai-0.80.8.tgz",
		"@earendil-works/pi-coding-agent": "https://registry.npmjs.org/@atharva-again/pi-coding-agent/-/pi-coding-agent-0.80.8-pi-tg.0.tgz",
		"@earendil-works/pi-tui": "https://registry.npmjs.org/@earendil-works/pi-tui/-/pi-tui-0.80.8.tgz"
	},
	"devDependencies": {
		"shx": "0.4.0",
		"vitest": "4.1.9"
	}
}
